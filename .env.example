# Copy to .env.local and fill in real values.

# Supabase (required for app + AI assistant)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Scheduling Assistant (Groq)
GROQ_API_KEY=
NYLAS_API_KEY=
NYLAS_GRANT_ID=
# IANA TZ for interpreting parser date+time (e.g. America/Los_Angeles). Defaults to Etc/UTC.
NYLAS_DEFAULT_TIMEZONE=
RESEND_API_KEY=
# Verified sending identity (must match a domain you send from in Resend).
RESEND_FROM_EMAIL=
# Optional but recommended: signing secret from Resend webhook config for email.received (Svix verification).
RESEND_WEBHOOK_SECRET=
